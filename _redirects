# Pricing alias — payment processors and other reviewers look for a /pricing URL.
# Serve the Great Physician Pro page (counsel.html) at /pricing too.
/pricing                      /counsel.html                                   200

# Inductive Group Study invitations — rewrite (200) keeps the URL bar
# showing /join/<token>, page reads the token from JS. Tapping the link on a
# device WITH the app honors Universal Links / App Links and never reaches
# this page; the rewrite is the fallback for everyone else.
/join/*                       /join.html                                      200
